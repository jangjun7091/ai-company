{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Agent Task",
  "type": "object",
  "required": ["id", "objective", "owner_role", "allowed_scope", "verification", "status"],
  "properties": {
    "id": {"type": "string"},
    "objective": {"type": "string", "minLength": 1},
    "owner_role": {"type": "string"},
    "allowed_scope": {"type": "array", "items": {"type": "string"}},
    "forbidden_scope": {"type": "array", "items": {"type": "string"}},
    "dependencies": {"type": "array", "items": {"type": "string"}},
    "verification": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "human_approval_required": {"type": "boolean", "default": false},
    "status": {"enum": ["proposed", "approved", "active", "blocked", "verification", "completed", "rejected"]}
  },
  "additionalProperties": false
}
